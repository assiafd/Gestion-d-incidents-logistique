APP_ENV=development
SECURE_MODE=true
HITL_MODE=console

# LLM provider
LLM_PROVIDER=groq
LLM_MODEL=deepseek-r1-distill-llama-70b
LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_TEMPERATURE=0.1

# Astra DataStax: Knowledge Graph persistence
ASTRA_DB_API_ENDPOINT=https://replace-me.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:replace-me
ASTRA_DB_KEYSPACE=default_keyspace
ASTRA_KG_COLLECTION=logistics_knowledge_graph

# MongoDB Atlas / online MongoDB: monitoring events and dashboard data
# Example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/incident_logistics_ai?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://replace-me:replace-me@replace-me.mongodb.net/incident_logistics_ai?retryWrites=true&w=majority
MONGODB_DATABASE=incident_logistics_ai
MONGODB_MONITORING_COLLECTION=monitoring_events

# Security thresholds
MAX_INPUT_CHARS=2500
MAX_CONTEXT_CHARS=8000
TOXICITY_THRESHOLD=0.75
HALLUCINATION_MIN_GROUNDEDNESS=0.55
MAX_ESTIMATED_COST_USD=0.15

# Dashboards
BUSINESS_DASHBOARD_PORT=8501
MONITORING_DASHBOARD_PORT=8502
